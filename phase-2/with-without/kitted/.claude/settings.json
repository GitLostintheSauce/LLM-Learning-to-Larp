{
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Bash(python3 validate.py:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 validate.py index.html"
          }
        ]
      }
    ]
  }
}
